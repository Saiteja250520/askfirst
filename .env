# LLM Providers Configuration
# Fill in the API key for the provider you wish to use.
# The backend will automatically select the active key.

# Google Gemini API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Groq API
GROQ_API_KEY=

# Chosen Active Provider: "gemini", "openai", or "groq"
# If not specified, the system will auto-detect based on available keys.
LLM_PROVIDER=

# Server Configurations
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./askfirst.db
PORT=8000
